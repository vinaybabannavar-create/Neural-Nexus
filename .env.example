# ============================================================
# CORRECTIVE RAG — Environment Variables
# Copy this to .env and fill in your actual keys
# ============================================================

# LLM Provider
OPENAI_API_KEY=sk-...
DEEPSEEK_API_KEY=sk-...

# Vector DB (chroma = local, no key needed)
CHROMA_PERSIST_DIR=./chroma_db
# PINECONE_API_KEY=pcsk_...
# PINECONE_ENV=us-east-1-aws
# PINECONE_INDEX_NAME=corrective-rag

# Web Search
TAVILY_API_KEY=tvly-...

# App Settings
VECTOR_STORE=chroma
LLM_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
GENERATION_MODEL=gpt-4o-mini
GRADER_MODEL=deepseek-reasoner
TOP_K_RETRIEVAL=4
RELEVANCE_THRESHOLD=0.5
MAX_RETRIES=2
